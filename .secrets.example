# MyndAIX Bridge — example secrets file.
# Copy to ~/.myndaix/.secrets and chmod 600 before adding any real values.
#
#   cp .secrets.example ~/.myndaix/.secrets
#   chmod 600 ~/.myndaix/.secrets
#   $EDITOR ~/.myndaix/.secrets
#
# All values default to empty. Watchers fail-closed when a key is unset
# (no notification, no API call) — they never invent credentials.

# ─── API keys ────────────────────────────────────────────────────────────────
# Used by watchers/recon-watcher.sh + tools/cost-tracker.sh.
export PERPLEXITY_API_KEY=""

# Used by watchers/kilabz-watcher.sh as a Codex fallback. Oracle uses a separate
# OAuth path via the gemini CLI (`gemini auth login`), NOT this key.
export GEMINI_API_KEY=""

# Reserved for TTS in audio/tts-bridge.sh; no active consumer at v1.0.
export ELEVENLABS_API_KEY=""

# ─── Notification webhooks (optional) ────────────────────────────────────────
# Primary Discord webhook for inbox-watcher result notifications.
# When unset, send_discord() is a no-op (fail-closed).
export DISCORD_WEBHOOK=""

# Used by scripts/create-task.sh for task-creation pings.
export DISCORD_WEBHOOK_TASKS=""

# Used by scripts/auto-router.sh for routing alerts.
export DISCORD_WEBHOOK_ALERTS=""

# ─── Two-machine networking (optional) ───────────────────────────────────────
# Set these only if you run agents across two Macs over Tailscale or LAN.
# All are optional — single-machine setups can leave them empty.
export MINI_TAILSCALE_IP=""        # e.g. 100.64.0.5
export MACBOOK_TAILSCALE_IP=""     # e.g. 100.64.0.7
export MINI_LAN_IP=""              # e.g. 192.168.1.10
export MACBOOK_LAN_IP=""           # e.g. 192.168.1.11
export MINI_SSH_USER=""            # ssh login user on the Mini
export MACBOOK_SSH_USER=""         # ssh login user on the MacBook
export MINI_HOSTNAME=""            # e.g. my-mini.local
export PEER_HOME=""                # peer machine's $HOME, used by mack-watcher.sh
                                   #   for path translation across the bridge

# Pipe-separated allowlist consumed by hooks/pre-dispatch-gate.sh.
# Block dispatch/SCP unless the destination matches one of these patterns.
# Example: "100.64.|jefe@|my-mini.local"
export ALLOWED_TARGETS=""
